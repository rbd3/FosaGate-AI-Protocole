# FosaGate AI — API Gateway Configuration

# Server
PORT=3000

# Evaluator signing key (same key registered on-chain)
EVALUATOR_PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80

# On-chain contract addresses (Arbitrum Sepolia)
ROUTER_ADDRESS=0x...
AGENT_REGISTRY_ADDRESS=0x...
VERDICT_LOG_ADDRESS=0x...

# RPC
ARBITRUM_RPC_URL=https://sepolia-rollup.arbitrum.io/rpc
CHAIN_ID=421614

# API Authentication
# Comma-separated list of valid API keys for agents
API_KEYS=fosagate-test-key-001,fosagate-test-key-002

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=30
