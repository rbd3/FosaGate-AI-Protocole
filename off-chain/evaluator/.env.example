# FosaGate Off-Chain Evaluator - Environment Variables

# The private key of the authorized evaluator signing authority.
# The corresponding address must be registered as the evaluator on-chain (e.g. in RiskEngine / FosaGateRouter).
EVALUATOR_PRIVATE_KEY=0x...

# Optional: Arbitrum Sepolia or Arbitrum One RPC provider URL (for on-chain simulations, code checks, and gas estimation)
ARBITRUM_RPC_URL=https://sepolia-rollup.arbitrum.io/rpc

# Optional: AI Model Configuration (Gemini API Key for contextual reasoning)
GEMINI_API_KEY=your-gemini-api-key-here
